---
import BettingView from "../components/BettingView.tsx";
import Layout from "../layouts/Layout.astro";

const PUBLIC_API_BASE =
  import.meta.env.PUBLIC_API_URL ?? "http://localhost:8080";
---

<Layout title="Bet console - Data" active="data" showFeed={false}>
  <div class="page-head">
    <span class="eyebrow">Records</span>
    <h1>Data</h1>
    <p>Inspect all bets and settlements for a specific user.</p>
  </div>

  <BettingView apiBaseUrl={PUBLIC_API_BASE} client:load />
</Layout>
